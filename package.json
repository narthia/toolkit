{
  "name": "@narthia/toolkit",
  "version": "0.0.0",
  "description": "Narthia's shared toolkit — oxc configs, OpenAPI helpers, and more.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./oxc-config": "./dist/oxc-config/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "dev": "vp pack --watch",
    "prepare": "vp config",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bumpp": "^11.1.0",
    "eslint-plugin-check-file": "^3.3.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "^0.2.5"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
